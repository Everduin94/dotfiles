# ==============================
# Core Git Configuration
# ==============================
[core]
    editor = nvim

[alias]
    co = checkout
    br = branch
    ci = commit
    st = status
    brb = checkout -b

[push]
    default = current

[credential "https://github.com"]
    helper =
    helper = !gh auth git-credential

[credential "https://gist.github.com"]
    helper =
    helper = !gh auth git-credential

[user]
	name = PLACE_HOLDER
	email = PLACE_HOLDER
